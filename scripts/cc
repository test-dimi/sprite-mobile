#!/bin/bash
# cc - Claude Code wrapper that auto-resumes the active session
#
# Instead of starting a fresh Claude process, this checks for an active
# sprite-mobile session and resumes it. This prevents multiple Claude
# processes from fighting over the same directory.
#
# Install: ln -sf ~/.sprite-mobile/scripts/cc /usr/local/bin/cc

ACTIVE_SESSION_FILE="$HOME/.claude-hub/active-session"

SESSION=$(cat "$ACTIVE_SESSION_FILE" 2>/dev/null)
if [ -n "$SESSION" ]; then
  echo "Resuming active session: $SESSION"
  exec claude --resume "$SESSION" "$@"
else
  # No active session - check for recent .jsonl files
  RECENT=$(find "$HOME/.claude/projects" -name "*.jsonl" -mmin -60 2>/dev/null | head -1)
  if [ -n "$RECENT" ]; then
    SESSION_ID=$(basename "$RECENT" .jsonl)
    echo "Found recent session: $SESSION_ID"
    exec claude --resume "$SESSION_ID" "$@"
  else
    exec claude "$@"
  fi
fi
